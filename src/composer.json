{
  "name": "baseons/framework",
  "type": "project",
  "description": "The Baseons framework",
  "keywords": [
    "framework",
    "baseons"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Warley Rodrigues de Moura",
      "email": "baseons@hotmail.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\": "database/",
      "Baseons\\": "core"
    },
    "files": [
      "core/Collections/Helpers.php"
    ]
  },
  "scripts": {
    "post-autoload-dump": [
      "@php baseons composer"
    ],
    "post-root-package-install": [
      "@php baseons composer"
    ],
    "post-create-project-cmd": [
      "@php baseons composer"
    ]
  },
  "require": {
    "php": "^8.4"
  },
  "require-dev": {
    "swoole/ide-helper": "^5.1"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}